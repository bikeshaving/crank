{
  "name": "@b9g/crank",
  "version": "0.7.9",
  "repository": {
    "type": "git",
    "url": "https://github.com/bikeshaving/crank.git"
  },
  "type": "module",
  "main": "./dist/src/crank.cjs",
  "module": "./dist/src/crank.js",
  "types": "./dist/src/crank.d.ts",
  "devDependencies": {
    "@b9g/libuild": "^0.1.24",
    "@types/node": "^22.14.0",
    "@types/sinon": "^17.0.4",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-crank": "workspace:*",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react": "^7.37.5",
    "playwright-test": "^14.1.9",
    "prettier": "^3.5.3",
    "sinon": "^17.0.2",
    "typescript": "^5.8.3",
    "uvu": "^0.5.6"
  },
  "bugs": {
    "url": "https://github.com/bikeshaving/crank/issues"
  },
  "description": "The Just JavaScript UI Framework.",
  "homepage": "https://crank.js.org",
  "license": "MIT",
  "private": true,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "libuild build",
    "publish": "libuild publish",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx .",
    "test": "npm run test:core && npm run test:eslint && npm run test:crankdown",
    "test:core": "playwright-test --runner uvu",
    "test:crankdown": "cd packages/crankdown && npm run typecheck && bun test",
    "test:eslint": "cd packages/eslint-plugin-crank && bun test",
    "typecheck": "tsc --noEmit",
    "skill": "npx @b9g/skillpack docs/SKILL.md -o skills/",
    "prepublishOnly": "echo 'ERROR: Cannot publish from root directory. Use libuild publish instead.' && exit 1"
  },
  "workspaces": [
    "packages/*"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/crank.d.ts",
      "import": "./dist/src/crank.js",
      "require": "./dist/src/crank.cjs"
    },
    "./async": {
      "types": "./dist/src/async.d.ts",
      "import": "./dist/src/async.js",
      "require": "./dist/src/async.cjs"
    },
    "./async.js": {
      "types": "./dist/src/async.d.ts",
      "import": "./dist/src/async.js",
      "require": "./dist/src/async.cjs"
    },
    "./crank": {
      "types": "./dist/src/crank.d.ts",
      "import": "./dist/src/crank.js",
      "require": "./dist/src/crank.cjs"
    },
    "./crank.js": {
      "types": "./dist/src/crank.d.ts",
      "import": "./dist/src/crank.js",
      "require": "./dist/src/crank.cjs"
    },
    "./dom": {
      "types": "./dist/src/dom.d.ts",
      "import": "./dist/src/dom.js",
      "require": "./dist/src/dom.cjs"
    },
    "./dom.js": {
      "types": "./dist/src/dom.d.ts",
      "import": "./dist/src/dom.js",
      "require": "./dist/src/dom.cjs"
    },
    "./event-target": {
      "types": "./dist/src/event-target.d.ts",
      "import": "./dist/src/event-target.js",
      "require": "./dist/src/event-target.cjs"
    },
    "./event-target.js": {
      "types": "./dist/src/event-target.d.ts",
      "import": "./dist/src/event-target.js",
      "require": "./dist/src/event-target.cjs"
    },
    "./html": {
      "types": "./dist/src/html.d.ts",
      "import": "./dist/src/html.js",
      "require": "./dist/src/html.cjs"
    },
    "./html.js": {
      "types": "./dist/src/html.d.ts",
      "import": "./dist/src/html.js",
      "require": "./dist/src/html.cjs"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/src/jsx-dev-runtime.d.ts",
      "import": "./dist/src/jsx-dev-runtime.js",
      "require": "./dist/src/jsx-dev-runtime.cjs"
    },
    "./jsx-dev-runtime.js": {
      "types": "./dist/src/jsx-dev-runtime.d.ts",
      "import": "./dist/src/jsx-dev-runtime.js",
      "require": "./dist/src/jsx-dev-runtime.cjs"
    },
    "./jsx-runtime": {
      "types": "./dist/src/jsx-runtime.d.ts",
      "import": "./dist/src/jsx-runtime.js",
      "require": "./dist/src/jsx-runtime.cjs"
    },
    "./jsx-runtime.js": {
      "types": "./dist/src/jsx-runtime.d.ts",
      "import": "./dist/src/jsx-runtime.js",
      "require": "./dist/src/jsx-runtime.cjs"
    },
    "./jsx-tag": {
      "types": "./dist/src/jsx-tag.d.ts",
      "import": "./dist/src/jsx-tag.js",
      "require": "./dist/src/jsx-tag.cjs"
    },
    "./jsx-tag.js": {
      "types": "./dist/src/jsx-tag.d.ts",
      "import": "./dist/src/jsx-tag.js",
      "require": "./dist/src/jsx-tag.cjs"
    },
    "./standalone": {
      "types": "./dist/src/standalone.d.ts",
      "import": "./dist/src/standalone.js",
      "require": "./dist/src/standalone.cjs"
    },
    "./standalone.js": {
      "types": "./dist/src/standalone.d.ts",
      "import": "./dist/src/standalone.js",
      "require": "./dist/src/standalone.cjs"
    },
    "./umd": {
      "require": "./dist/src/umd.js"
    },
    "./umd.js": {
      "require": "./dist/src/umd.js"
    },
    "./package.json": "./dist/package.json"
  }
}
